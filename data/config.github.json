{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "glm-4-flash-250414",
    "base_url": "https://open.bigmodel.cn/api/paas/v4/",
    "api_key_env": "ZHIPU_API_KEY",
    "temperature": 0.4,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": [
      "zh",
      "en"
    ],
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "sources": {
    "github": [],
    "github_search": {
      "enabled": true,
      "queries": [
        "AI agent created:>2026-07-01 stars:>50 sort:stars-desc",
        "LLM created:>2026-07-01 stars:>50 sort:stars-desc",
        "RAG created:>2026-07-01 stars:>30 sort:stars-desc",
        "text-to-image created:>2026-07-01 stars:>50 sort:stars-desc",
        "text-to-video created:>2026-07-01 stars:>30 sort:stars-desc",
        "code-generation created:>2026-07-01 stars:>50 sort:stars-desc",
        "voice-clone created:>2026-07-01 stars:>30 sort:stars-desc",
        "AI tool stars:>500 pushed:>2026-07-10 sort:stars-desc"
      ],
      "sort": "stars",
      "order": "desc",
      "per_page": 15,
      "category": "github-hot"
    },
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 40,
      "min_score": 30,
      "category": "show-hn"
    },
    "reddit": {
      "enabled": false
    },
    "telegram": {
      "enabled": false
    },
    "twitter": {
      "enabled": false
    },
    "rss": [],
    "openbb": {
      "enabled": false
    },
    "google_news": {
      "enabled": false
    },
    "ossinsight": {
      "enabled": false
    },
    "gdelt": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 48,
    "max_items": 15,
    "category_groups": {
      "github": {
        "name": "GitHub 热门项目",
        "limit": 10,
        "categories": ["github-hot"]
      },
      "show-hn": {
        "name": "Show HN 新项目",
        "limit": 5,
        "categories": ["show-hn"]
      }
    },
    "default_group": "other",
    "default_group_limit": 2
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {},
    "headers": ""
  }
}
